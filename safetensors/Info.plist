<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Basic bundle metadata normally generated by Xcode; kept here so this plist can also document the file-type registration. -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>NSHumanReadableCopyright</key>
	<string></string>
	<key>NSMainStoryboardFile</key>
	<string>Main</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>

	<!-- Declare the app as a viewer for files whose content type is the custom safetensors UTType below. -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>safetensors file</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<!-- Legacy extension mapping helps older Launch Services paths recognize .safetensors even before Spotlight has refreshed metadata. -->
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>safetensors</string>
			</array>
			<key>LSItemContentTypes</key>
			<array>
				<string>io.util.safetensors.file</string>
			</array>
		</dict>
	</array>

	<!-- Export a Uniform Type Identifier so Launch Services and QuickLook can associate .safetensors paths with this app. -->
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<!-- This app owns the safetensors UTI, which lets Finder match .safetensors files to the viewer and QuickLook extension. -->
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeDescription</key>
			<string>safetensors file</string>
			<key>UTTypeIdentifier</key>
			<string>io.util.safetensors.file</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>safetensors</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
